{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "types": ["node"],
    "jsx": "react-jsx",
    "incremental": false
  },
  "include": [
    "src/lib/utils.ts",
    "src/lib/cart-utils.ts",
    "src/types/index.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
